# Hostname or IP of the Raspberry Pi
PI_HOST=localhost

# HTTP port (used by watcher and simulator)
PI_PORT=8080

# Polling interval in seconds
POLL_INTERVAL=0.5

# Shell commands to control the physical USB lamp via uhubctl.
# Leave empty to run in simulator mode (no hardware).
LAMP_CMD_ON=
LAMP_CMD_OFF=

# Example for Raspberry Pi with uhubctl:
# LAMP_CMD_ON=sudo uhubctl -l 1-1 -a on
# LAMP_CMD_OFF=sudo uhubctl -l 1-1 -a off

# Directory for day-based session CSVs (default: ~/Library/Application Support/mic_watch/sessions)
# Files: 2026-03-19.csv, 2026-03-20.csv, ...
# SESSION_DIR=~/Documents/mic_watch/sessions
